# ==============================
# DISCORD BOT - CONFIGURAZIONE
# ==============================

# Token del bot Discord (obbligatorio)
DISCORD_TOKEN=il_tuo_token_qui

# Client ID e Secret per OAuth2 (dashboard web)
CLIENT_ID=il_tuo_client_id
CLIENT_SECRET=il_tuo_client_secret

# URL del redirect OAuth2 (es. http://localhost:3000/auth/discord/callback)
CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Secret per le sessioni Express
SESSION_SECRET=una_stringa_segreta_casuale

# Porta del server web (default 3000)
PORT=3000

# Metti 'true' solo la prima volta per registrare i comandi slash
REGISTER_COMMANDS=false

# ==============================
# DATABASE
# ==============================
# ✅ Nessuna configurazione necessaria!
# Il database è ora SQLite locale → file: data/bot.db
# Creato automaticamente all'avvio del bot.
